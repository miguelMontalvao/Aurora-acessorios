# ───────────────────────────────────────
# Aurora Acessórios — .gitignore
# Stack: Vite + React + TypeScript
# ───────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
dist-ssr/
build/

# Environment variables (NUNCA suba ao repositório)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# TypeScript
*.tsbuildinfo

# Testing & Coverage
coverage/
.nyc_output/

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.temp/
.tmp/

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Package managers (use apenas um)
yarn.lock        # remova esta linha se usar Yarn
pnpm-lock.yaml   # remova esta linha se usar pnpm
# package-lock.json # remova o comentário se quiser ignorar o lock do npm

# Storybook (se adicionar no futuro)
storybook-static/

# Misc
*.orig
*.bak
*.backup
